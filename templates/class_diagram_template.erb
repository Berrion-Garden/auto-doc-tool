<%# auto-doc class diagram template %>
<%# Available: title, classes, generated_at %>

> Class Diagram: <%= title %>
> Generated by auto-doc on <%= generated_at %>

classDiagram
<% classes.each do |cls| %>
    class <%= cls[:name] %> {
<% if cls[:methods] && cls[:methods].any? %>
<% cls[:methods].each do |m| %>
        <%= m %>
<% end %>
<% end %>
    }
<% if cls[:parent] %>
    <%= cls[:parent] %> <|-- <%= cls[:name] %>
<% end %>
<% if cls[:includes] %>
<% cls[:includes].each do |inc| %>
    <%= inc %> <|.. <%= cls[:name] %>
<% end %>
<% end %>
<% if cls[:extends] %>
    <%= cls[:name] %> --|> <%= cls[:extends] %>
<% end %>
<% end %>
